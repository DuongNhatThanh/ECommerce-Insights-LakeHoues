FROM ubuntu:22.04

LABEL maintainer="TrungNghia <trungnghia294@gmail.com>"
LABEL version="2.0"

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Ho_Chi_Minh

ENV JAVA_HOME=/usr/lib/jvm/java-11-openjdk-amd64
ENV SPARK_VERSION=3.5.1
ENV HADOOP_VERSION=3
ENV SPARK_SHA512=3d8e3f082c602027d540771e9eba9987f8ea955e978afc29e1349eb6e3f9fe32543e3d3de52dff048ebbd789730454c96447c86ff5b60a98d72620a0f082b355
ENV SPARK_HOME=/opt/spark
ENV PYTHONHASHSEED=1

RUN apt-get update && apt-get install -y \
    curl \
    wget \
    vim \
    openssh-server \
    net-tools \
    ca-certificates \
    python3 \
    python3-pip \
    python3-venv \
    openjdk-11-jdk \
    rsync \
    procps \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /var/run/sshd /root/.ssh && \
    ssh-keygen -t rsa -f /root/.ssh/id_rsa -P "" && \
    cat /root/.ssh/id_rsa.pub >> /root/.ssh/authorized_keys && \
    chmod 600 /root/.ssh/authorized_keys && \
    echo "StrictHostKeyChecking no" >> /root/.ssh/config

RUN echo 'root:thanhdn' | chpasswd && \
    sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config && \
    sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config

RUN set -eux; \
    spark_archive="spark-${SPARK_VERSION}-bin-hadoop${HADOOP_VERSION}.tgz"; \
    downloaded=0; \
    for spark_base_url in \
        "https://mirrors.huaweicloud.com/apache/spark" \
        "https://mirror.lyrahosting.com/apache/spark" \
        "https://archive.apache.org/dist/spark"; \
    do \
        if curl -fL --connect-timeout 15 --retry 2 --retry-delay 2 \
            "${spark_base_url}/spark-${SPARK_VERSION}/${spark_archive}" \
            -o "/tmp/${spark_archive}"; then \
            downloaded=1; \
            break; \
        fi; \
    done; \
    test "${downloaded}" = "1"; \
    cd /tmp; \
    echo "${SPARK_SHA512}  ${spark_archive}" | sha512sum -c -; \
    tar -xzf "/tmp/${spark_archive}" -C /opt; \
    mv "/opt/spark-${SPARK_VERSION}-bin-hadoop${HADOOP_VERSION}" /opt/spark; \
    rm "/tmp/${spark_archive}"

COPY conf/* /opt/spark/conf/
RUN sed -i 's/\r$//' /opt/spark/conf/*

RUN update-alternatives --install /usr/bin/python python /usr/bin/python3 1

RUN python -m pip install --no-cache-dir \
    hdfs \
    pyspark==${SPARK_VERSION} \
    delta-spark==3.1.0 \
    pandas \
    numpy \
    pyarrow

WORKDIR /opt/spark

ENV SPARK_MASTER_PORT=7077
ENV SPARK_MASTER_WEBUI_PORT=8080
ENV SPARK_WORKER_WEBUI_PORT=8081
ENV SPARK_WORKER_PORT=7000
ENV SPARK_LOG_DIR=/opt/spark/logs
ENV SPARK_MASTER=spark://spark-master:7077
ENV SPARK_WORKLOAD=master
ENV PATH=$PATH:$SPARK_HOME/bin:$SPARK_HOME/sbin

RUN mkdir -p $SPARK_LOG_DIR

COPY start-spark.sh /start-spark.sh
RUN sed -i 's/\r$//' /start-spark.sh && chmod +x /start-spark.sh

EXPOSE 7077 8080 8081 7000 22

CMD ["/bin/bash", "/start-spark.sh"]
